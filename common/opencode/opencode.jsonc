{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.3-codex",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://ollama.com/v1"
      }
    }
  },
  "mcp": {
    "context7": {
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}
